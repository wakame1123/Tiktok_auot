# TikTok Developer App (https://developers.tiktok.com/)
TIKTOK_CLIENT_KEY=your_client_key
TIKTOK_CLIENT_SECRET=your_client_secret

# OAuth redirect URI (TikTok Developer Portal に登録した URL と一致させる)
TIKTOK_REDIRECT_URI=http://127.0.0.1:8765/callback

# 監視フォルダ（未設定時は ./watch にフォールバック）
WATCH_FOLDER=./watch

# 投稿モード: direct（即時公開） / draft（TikTok受信箱に下書き）
POST_MODE=direct

# デフォルト公開範囲: PUBLIC_TO_EVERYONE / MUTUAL_FOLLOW_FRIENDS / SELF_ONLY
PRIVACY_LEVEL=PUBLIC_TO_EVERYONE

# 時間予告キャプションテンプレート
# {live_time} {title} {hashtags} が利用可能
CAPTION_TEMPLATE={title}\n\n{live_time} からLIVE配信します！\nリマインダー設定お願いします🙏\n\n{hashtags}

# デフォルトハッシュタグ（カンマ区切り）
DEFAULT_HASHTAGS=TikTokLIVE,ライブ告知,時間予告

# Web UI ポート
WEB_PORT=8765
